# ─── Deployment ─────────────────────────────────────────────────────────────
# Required: full URL where the app is hosted
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                         # openssl rand -base64 32

# ─── Database (Railway PostgreSQL) ───────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/almanar?schema=public
# Add ?connection_limit=5 in production on Railway

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Membership price IDs — create in Stripe Dashboard → Products
STRIPE_MEMBERSHIP_PRICE_MONTHLY=price_...
STRIPE_MEMBERSHIP_PRICE_ANNUAL=price_...

# ─── AWS S3 ──────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=almanar-prod
# Optional: CloudFront CDN prefix for video delivery (faster, no expiry issues)
AWS_CLOUDFRONT_URL=https://xxxxxx.cloudfront.net

# ─── Resend (Email) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@almanar.com
RESEND_FROM_NAME=ALMANAR
# Resend Audience ID for free-product mailing list signups
RESEND_AUDIENCE_ID=

# ─── App Config ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
BILLING_CURRENCY=usd
DEFAULT_LOCALE=ar                        # ar | en — Arabic is the default

# ─── Download Security ───────────────────────────────────────────────────────
# Hours a download link stays valid before expiring
DOWNLOAD_LINK_TTL_HOURS=48
# Max re-downloads per purchase
DOWNLOAD_MAX_REGENERATIONS=5
